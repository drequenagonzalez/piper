{
    "name": "spatie/piper",
    "description": "Pipe-native plain array functions inspired by Laravel collections.",
    "keywords": [
        "spatie",
        "piper",
        "collections",
        "arrays",
        "pipe"
    ],
    "homepage": "https://github.com/spatie/piper",
    "license": "MIT",
    "authors": [
        {
            "name": "Spatie",
            "email": "info@spatie.be",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5"
    },
    "require-dev": {
        "laravel/pint": "^1.24",
        "pestphp/pest": "^4.0",
        "psy/psysh": "^0.12.22"
    },
    "autoload": {
        "files": [
            "src/functions.php"
        ],
        "psr-4": {
            "Spatie\\Piper\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Spatie\\Piper\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
